<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head') %>
</head>
<body>
    <%- include('../partials/navbar') %>
    <div class="container">
        <h2 class="mb-3">Borrow Ticket Requests</h2>
        <%- include('../partials/alert') %>

        <% if (tickets && tickets.length > 0) { %>
            <div class="row g-3">
                <% for (let i = 0; i < tickets.length; i++) { %>
                    <% const ticket = tickets[i]; %>
                    <div class="col-12">
                        <div class="card shadow-sm">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <h5 class="card-title mb-1"><%= ticket.equipment_name %></h5>
                                        <p class="text-muted mb-2">Student: <%= ticket.username %> | Requested on <%= ticket.request_date %></p>
                                    </div>
                                    <span class="badge bg-info text-dark"><%= ticket.status %></span>
                                </div>
                                <p class="mb-2"><strong>Reason:</strong> <%= ticket.reason %></p>
                                <p class="mb-2"><strong>Due date:</strong> <%= ticket.due_date %></p>
                                <p class="mb-3"><strong>Review note:</strong> <%= ticket.review_note || 'No review yet.' %></p>

                                <% if (ticket.status === 'pending') { %>
                                    <div class="d-flex gap-2">
                                        <form action="/admin/tickets/<%= ticket.ticket_id %>/approve" method="POST">
                                            <button type="submit" class="btn btn-success">Approve</button>
                                        </form>
                                        <form action="/admin/tickets/<%= ticket.ticket_id %>/reject" method="POST">
                                            <div class="input-group">
                                                <input type="text" name="reviewNote" class="form-control" placeholder="Reason for rejection" required>
                                                <button type="submit" class="btn btn-danger">Reject</button>
                                            </div>
                                        </form>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
        <% } else { %>
            <div class="alert alert-light border">No borrow requests yet.</div>
        <% } %>
    </div>
    <%- include('../partials/footer') %>
</body>
</html>
