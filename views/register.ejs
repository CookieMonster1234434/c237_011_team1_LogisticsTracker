<!DOCTYPE html>
<html lang="en">
<%# Expects locals: pageTitle = 'Register' passed in from the route render() call %>
<head>
    <%- include('partials/head') %>
</head>
<body>
    <%- include('partials/navbar') %>
    <div class="container">
        <div class="card auth-card shadow-sm">
            <div class="card-body p-4">
                <h3 class="card-title mb-4 text-center">Create an Account</h3>
                <%- include('partials/alert') %>
                
                <%# Form action dynamically switches between /register and /admin/register %>
                <form id="registerForm" action="/register" method="POST">
                    <div class="mb-3">
                        <label for="username" class="form-label">Username</label>
                        <input type="text" class="form-control" id="username" name="username" required>
                    </div>

                    <div class="mb-3">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" class="form-control" id="email" name="email" required>
                    </div>

                    <div class="mb-3">
                        <label for="password" class="form-label">Password</label>
                        <input type="password" class="form-control" id="password" name="password" minlength="6" required>
                    </div>

                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" id="adminToggle">
                        <label class="form-check-label" for="adminToggle">
                            Register as Admin
                        </label>
                    </div>

                    <div class="mb-3" id="adminKeyGroup" style="display: none;">
                        <label for="adminKey" class="form-label">Admin Secret Key</label>
                        <input type="password" class="form-control" id="adminKey" name="adminKey" placeholder="Enter Secret Key">
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Register</button>
                </form>

                <p class="text-center mt-3 mb-0">
                    Already have an account? <a href="/login">Login here</a>
                </p>
            </div>
        </div>
    </div>
    <%- include('partials/footer') %>

    <script>
        const adminToggle = document.getElementById('adminToggle');
        const adminKeyGroup = document.getElementById('adminKeyGroup');
        const adminKeyInput = document.getElementById('adminKey');
        const registerForm = document.getElementById('registerForm');

        adminToggle.addEventListener('change', function () {
            if (this.checked) {
                // Show admin secret key input & update route
                adminKeyGroup.style.display = 'block';
                adminKeyInput.required = true;
                registerForm.action = '/admin/register';
            } else {
                // Hide input, clear value, & reset back to normal user route
                adminKeyGroup.style.display = 'none';
                adminKeyInput.required = false;
                adminKeyInput.value = '';
                registerForm.action = '/register';
            }
        });
    </script>
</body>
</html>