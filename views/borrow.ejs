<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('./partials/head', { pageTitle: 'Borrow Equipment' }) %>
</head>
<body>
  <%- include('./partials/navbar', { user: user }) %>

  <div class="container mt-5">
    <h2 class="mb-4">Borrow Equipment</h2>

    <%- include('./partials/alert') %>

    <form action="/equipment/<%= equipmentId %>/borrow" method="POST">
      <div class="mb-3">
        <label for="duration" class="form-label">Borrow Duration (days)</label>
        <input type="number" id="duration" name="duration" class="form-control" min="1" max="7" required>
      </div>

    <div class="mb-3">
    <label for="quantity" class="form-label">Quantity to Borrow</label>
    <input type="number" id="quantity" name="quantity" class="form-control" min="1" max="<%= equipment.available_quantity %>" required>
  </div>

      <div class="mb-3">
        <label for="reason" class="form-label">Reason for Borrowing</label>
        <textarea id="reason" name="reason" class="form-control" rows="3" placeholder="e.g., project work" required></textarea>
      </div>

      <button type="submit" class="btn btn-primary">Confirm Borrow</button>
    </form>
  </div>

  <%- include('./partials/footer') %>
</body>
</html>
