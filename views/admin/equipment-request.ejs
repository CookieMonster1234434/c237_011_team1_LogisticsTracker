

<%- include('../partials/header', { pageTitle: pageTitle }) %>

<div class="container mt-4 mb-5">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Equipment Requests</h2>
    <span class="badge bg-secondary"><%= requests.length %> total</span>
  </div>

  <div class="table-responsive">
    <table class="table table-hover align-middle">
      <thead class="table-light">
        <tr>
          <th>#</th>
          <th>Requested By</th>
          <th>Item</th>
          <th>Category</th>
          <th>Qty</th>
          <th>Description</th>
          <th>Date</th>
          <th>Status</th>
          <th>Review Note</th>
        </tr>
      </thead>
      <tbody>
        <% if (requests.length === 0) { %>
          <tr>
            <td colspan="9" class="text-center text-muted py-4">No equipment requests found.</td>
          </tr>
        <% } %>

        <% requests.forEach(function(r) { %>
          <tr>
            <td><%= r.request_id %></td>
            <td><%= r.user_name || r.user_id %></td>
            <td><%= r.name %></td>
            <td><%= r.category %></td>
            <td><%= r.quantity %></td>
            <td style="max-width: 250px;">
              <span class="d-inline-block text-truncate" style="max-width: 250px;" title="<%= r.description %>">
                <%= r.description %>
              </span>
            </td>
            <td><%= new Date(r.request_date).toLocaleDateString() %></td>
            <td>
              <% if (r.status === 'pending') { %>
                <span class="badge bg-warning text-dark">Pending</span>
              <% } else if (r.status === 'approved') { %>
                <span class="badge bg-success">Approved</span>
              <% } else if (r.status === 'rejected') { %>
                <span class="badge bg-danger">Rejected</span>
              <% } else { %>
                <span class="badge bg-secondary"><%= r.status %></span>
              <% } %>
            </td>
            <td><%= r.review_note || '—' %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>
