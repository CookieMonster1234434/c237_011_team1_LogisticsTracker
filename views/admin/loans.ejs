<!DOCTYPE html>
<html lang="en">
<%#
    Expects locals:
      pageTitle = 'All Loans'
      user      = current session user (role: admin)
      loans     = [{ loan_id, username, name, borrow_date, due_date, return_date, status }, ...]
                   status is one of 'borrowed' | 'returned' | 'overdue'
      overdueCount = number of loans currently overdue (for the summary stat)
%>
<head>
    <%- include('../partials/head') %>
</head>
<body>
    <%- include('../partials/navbar') %>
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="mb-0">All Loans</h2>
            <div class="d-flex align-items-center gap-3">
                <span class="badge bg-danger fs-6">
                    <%= typeof overdueCount !== 'undefined' ? overdueCount : 0 %> overdue
                </span>
                <%# HONG WEI: removes all 'returned' loans at once to tidy the table %>
                <form action="/admin/loans/clear-returned" method="POST" class="d-inline"
                      onsubmit="return confirm('Remove all returned loan records?');">
                    <button type="submit" class="btn btn-sm btn-outline-secondary">Clear returned history</button>
                </form>
            </div>
        </div>
        <%- include('../partials/alert') %>
        <div class="table-responsive">
            <table class="table table-bordered align-middle bg-white">
                <thead class="table-light">
                    <tr>
                        <th>Student</th>
                        <th>Equipment</th>
                        <th>Borrow Date</th>
                        <th>Due Date</th>
                        <th>Return Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (typeof loans !== 'undefined' && loans.length > 0) { %>
                        <% for (let i = 0; i < loans.length; i++) { %>
                            <% const loan = loans[i]; %>
                            <tr class="<%= loan.status === 'overdue' ? 'table-row-overdue' : '' %>">
                                <td><%= loan.username %></td>
                                <td><%= loan.name %></td>
                                <td><%= loan.borrow_date %></td>
                                <td><%= loan.due_date %></td>
                                <td><%= loan.return_date ? loan.return_date : '—' %></td>
                                <td>
                                    <span class="badge status-badge-<%= loan.status %>"><%= loan.status %></span>
                                </td>
                                <td>
                                    <%# SHAKIR: force-return is only shown while the item is still out %>
                                    <% if (loan.status !== 'returned') { %>
                                        <form action="/admin/loans/<%= loan.loan_id %>/return" method="POST" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-success">Return</button>
                                        </form>
                                    <% } %>
                                    <%# HONG WEI: delete removes the loan record (with a confirm box) %>
                                    <form action="/admin/loans/<%= loan.loan_id %>/delete" method="POST" class="d-inline"
                                          onsubmit="return confirm('Delete this loan record?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        <% } %>
                    <% } else { %>
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">No loans recorded yet.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
    <%- include('../partials/footer') %>
</body>
</html>
