<!DOCTYPE html>
<html lang="en">
<%#
    Expects locals:
      pageTitle    = 'Equipment'
      user         = current session user or null
      equipmentList = [{ equipment_id, name, category, description, image, total_quantity, available_quantity, condition }, ...]
      categories   = ['Camera', 'Laptop', ...]   (distinct categories for the filter dropdown)
      searchQuery  = string (current search box value, '' if none)
      category     = string (current selected category filter, '' if 'All')
%>
<head>
    <%- include('../partials/head') %>
</head>
<body>
    <%- include('../partials/navbar') %>
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="mb-0">Equipment</h2>
            <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
                <a href="/admin/equipment/add" class="btn btn-primary">
                    <i class="bi bi-plus-lg"></i> Add Equipment
                </a>
            <% } %>
        </div>

        <%- include('../partials/alert') %>

        <form action="/equipment" method="GET" class="row g-2 mb-4">
            <div class="col-sm-6">
                <input type="text" name="search" class="form-control" placeholder="Search by equipment name..."
                       value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
            </div>
            <div class="col-sm-4">
                <select name="category" class="form-select">
                    <option value="">All Categories</option>
                    <% if (typeof categories !== 'undefined') { %>
                        <% categories.forEach(function(cat) { %>
                            <option value="<%= cat %>" <%= (typeof category !== 'undefined' && category === cat) ? 'selected' : '' %>><%= cat %></option>
                        <% }) %>
                    <% } %>
                </select>
            </div>
            <div class="col-sm-2 d-grid">
                <button type="submit" class="btn btn-outline-secondary">
                    <i class="bi bi-search"></i> Filter
                </button>
            </div>
        </form>

        <div class="row row-cols-1 row-cols-md-3 g-4">
            <% if (typeof equipmentList !== 'undefined' && equipmentList.length > 0) { %>
                <% equipmentList.forEach(function(item) { %>
                    <div class="col">
                        <div class="card equipment-card h-100 shadow-sm">
                            <img src="<%= item.image ? '/uploads/' + item.image : '/images/placeholder.svg' %>" class="card-img-top" alt="<%= item.name %>">
                            <div class="card-body">
                                <span class="badge bg-secondary mb-2 align-self-start"><%= item.category %></span>
                                <h5 class="card-title"><%= item.name %></h5>
                                <p class="card-text text-muted small flex-grow-1"><%= item.description %></p>
                                <p class="mb-2">
                                    <strong><%= item.available_quantity %></strong> / <%= item.total_quantity %> available
                                    &middot; Condition: <%= item.condition %>
                                </p>
                                <a href="/equipment/<%= item.equipment_id %>" class="btn btn-outline-primary mt-auto">View Details</a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-12">
                    <p class="text-muted text-center py-5">No equipment found.</p>
                </div>
            <% } %>
        </div>
    </div>
    <%- include('../partials/footer') %>
</body>
</html>
